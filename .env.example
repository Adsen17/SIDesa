# Salin file ini menjadi .env dan isi dengan nilai yang benar
# Copy this file to .env and fill in the correct values

# Database connection string (PostgreSQL / Neon / PlanetScale)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# JWT Secret - gunakan string acak yang panjang dan aman
JWT_SECRET="ganti-dengan-string-rahasia-yang-panjang-dan-aman"

# Environment
NODE_ENV="development"
